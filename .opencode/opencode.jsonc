{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser=chromium",
        "--no-sandbox",
        "--isolated",
        "--headless"
      ],
      "enabled": true
    },
    "searxng": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-searxng"
      ],
      "environment": {
        "SEARXNG_URL": "https://your-searxng.com"
      },
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-fetch-server"
      ],
      "enabled": true
    },
    "jina": {
      "type": "remote",
      "enabled": false,
      "url": "https://mcp.jina.ai/v1",
      "headers": {
        "JINA_API_KEY": "jina_keyItsFreeJsutGoogleem"
      }
    }
  }
}