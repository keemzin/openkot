#this is a test
#this is a test2
# ── OpenCode Version ───────────────────────────────────────────────────────
# Pin to a specific version. Change here to upgrade.
# Releases: https://github.com/anomalyco/opencode/releases
# NOTE: Linux ARM64 (Raspberry Pi) requires v1.4.11 or later
# Docker will automatically download the Linux binary for this version
OPENCODE_VERSION=v1.14.19

# ── Server ────────────────────────────────────────────────────────────────
# Port the web UI is served on
PORT=3006

# ── OpenCode Backend ───────────────────────────────────────────────────────
# Port opencode listens on internally (not exposed publicly)
OPENCODE_PORT=3358

# Host opencode binds to (127.0.0.1 = localhost only, 0.0.0.0 = all interfaces)
OPENCODE_HOST=0.0.0.0

# Path to the opencode binary (auto-detected based on OS if not set)
# Windows default: vendor/opencode/opencode.exe
# Linux/Mac default: vendor/opencode/opencode
# Leave empty to use local vendor binary (recommended)
# OPENCODE_BINARY=/home/hakeem/.opencode/bin/opencode

# Default working directory opencode starts in
# Can be relative to project root (e.g., WORKSPACE) or absolute path
# Relative paths are recommended for portability and Docker compatibility
WORKING_DIR=WORKSPACE

# ── Feature Flags ──────────────────────────────────────────────────────────
# Enable plan mode (AI writes PLAN.md before executing)
# PLAN_MODE=1

# ── Environment ────────────────────────────────────────────────────────────
NODE_ENV=development
#OPENCHAMBER_TERMINAL_SHELL=C:\Windows\System32\cmd.exe
#OPENCHAMBER_TERMINAL_SHELL=C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe
